# API Keys
RUNDOWN_API_KEY=your_rundown_api_key_here

# Verification Controls
EXECUTION_MODE=PAPER
SLIPPAGE_TOLERANCE_PCT=0.005

# Network Parameters
WALLET_PRIVATE_KEY=mock_key_for_simulation_purposes_only
POLYMARKET_API_KEY=read_only_public_tracking_key

# Database Parameters
POSTGRES_USER=sportsball_admin
POSTGRES_PASSWORD=changeme_in_env
POSTGRES_DB=market_history

# Broker Parameters
REDIS_HOST=redis

# Slack integration (all optional). Leave unset to disable alerts + approval
# gate entirely — the pipeline behaves exactly as before.
#   - Alerts need either a bot token OR a webhook URL.
#   - The Approve/Reject gate needs the bot token + an app-level token
#     (Socket Mode) AND SLACK_REQUIRE_APPROVAL=true.
SLACK_BOT_TOKEN=your_slack_bot_token_here          # xoxb-... (scope: chat:write)
SLACK_APP_TOKEN=your_slack_app_token_here          # xapp-... (Socket Mode, connections:write)
SLACK_WEBHOOK_URL=                                  # optional fallback for one-way alerts
SLACK_CHANNEL=#sportsball
SLACK_REQUIRE_APPROVAL=false
SLACK_APPROVAL_EV_THRESHOLD=0.10
SLACK_APPROVAL_TTL_SECS=900
